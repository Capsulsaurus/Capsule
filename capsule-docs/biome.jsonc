{
    "$schema": "https://biomejs.dev/schemas/2.5.1/schema.json",
    "extends": ["../biome.jsonc"],
    "files": {
        // Static assets under public/ (favicons, images) are not lint sources.
        "includes": ["**", "!public"]
    },
    "vcs": {
        // Required because as of March 2025, Biome doesn't check nested gitignore files otherwise
        "enabled": true,
        "clientKind": "git",
        "useIgnoreFile": true
    }
}
