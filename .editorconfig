root = true

[*.{kt,kts}]
# Never collapse imports into a wildcard (deterministic, merge-friendly import blocks).
ij_kotlin_name_count_to_use_star_import = 2147483647
ij_kotlin_name_count_to_use_star_import_for_members = 2147483647
# ktlint's official code style (strict).
ktlint_code_style = ktlint_official
# @Composable functions are PascalCase by Jetpack Compose convention — exempt them
# from the camelCase function-naming rule.
ktlint_function_naming_ignore_when_annotated_with = Composable
